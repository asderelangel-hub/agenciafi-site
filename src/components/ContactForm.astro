---
import { web3formsKey } from "../data/site";
---

<section class="fi-cta-section" id="contacto">
  <p class="fi-cta-heading fi-animate-fadein">
    ¿Quieres crecer y <span class="fi-accent">transformar</span> junto a nosotros?
  </p>
  <p class="fi-cta-sub fi-animate-fadein fi-delay-1">Déjanos tus datos aquí</p>

  <form
    class="fi-form fi-animate-fadein fi-delay-2"
    action="https://api.web3forms.com/submit"
    method="POST"
  >
    <input type="hidden" name="access_key" value={web3formsKey} />
    <input type="hidden" name="subject" value="Nuevo contacto desde agenciafi.cl" />
    <input type="hidden" name="from_name" value="Web Agencia Fi" />
    <input type="text" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

    <input type="text" name="nombre" placeholder="Nombre" required />
    <input type="email" name="email" placeholder="Email" required />
    <input type="text" name="empresa" placeholder="Empresa (opcional)" />
    <textarea name="mensaje" placeholder="Cuéntanos en qué te podemos ayudar" required></textarea>
    <button type="submit" class="fi-btn-accent" style="justify-content:center">Enviar</button>
  </form>
</section>
