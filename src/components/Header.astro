---
import { Image } from "astro:assets";
import { nav, site } from "../data/site";
import { img } from "../lib/media";
import { withBase } from "../lib/base";

const logo = img("logo-blanco.png");
const path = Astro.url.pathname;
---

<header class="fi-header-bar" id="fi-header">
  <a href={withBase("/")} class="fi-header-logo-link" aria-label="Agencia Fi — inicio">
    <Image src={logo} alt="Agencia Fi" class="fi-header-logo" />
  </a>

  <button class="fi-nav-toggle" aria-label="Abrir menú" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <div class="fi-header-nav-wrap">
    {
      nav.slice(1).map((item) => (
        <a
          href={withBase(item.href)}
          class="fi-nav-link"
          style={path === withBase(item.href) ? "color:#00E5CC" : undefined}
        >
          {item.label}
        </a>
      ))
    }
    <div class="fi-social-row">
      <a href={site.social.instagram} target="_blank" rel="noopener" class="fi-social-btn" aria-label="Instagram">IG</a>
      <a href={site.social.linkedin} target="_blank" rel="noopener" class="fi-social-btn" aria-label="LinkedIn">in</a>
      <a href={`mailto:${site.email}`} class="fi-social-btn" aria-label="Email">@</a>
    </div>
  </div>
</header>
