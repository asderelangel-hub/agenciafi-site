---
import { Image } from "astro:assets";
import { site } from "../data/site";
import { img } from "../lib/media";
import { withBase } from "../lib/base";

const logo = img("logo-secundario.png");
const year = 2024;
---

<footer class="fi-footer-section">
  <div class="fi-footer-grid">
    <div>
      <Image src={logo} alt="Agencia Fi" class="fi-footer-logo" />
      <p class="fi-footer-desc">
        Somos la agencia de comunicaciones que acompaña a sus clientes en su
        viaje e historia comunicacional a través de estrategias de impacto.
      </p>
    </div>
    <div>
      <a href={withBase("/somos-fi")} class="fi-footer-nav-link">Somos Fi</a>
      <a href={withBase("/mirada-fi")} class="fi-footer-nav-link">Mirada Fi</a>
    </div>
    <div>
      <h3 class="fi-footer-contact-title">Contáctanos</h3>
      <div class="fi-footer-social-row">
        <a href={site.social.instagram} target="_blank" rel="noopener" class="fi-footer-social-link">Instagram</a>
        <a href={site.social.linkedin} target="_blank" rel="noopener" class="fi-footer-social-link">LinkedIn</a>
        <a href={`mailto:${site.email}`} class="fi-footer-social-link">Email</a>
      </div>
      <div class="fi-footer-info-item">
        <a href={site.whatsapp} target="_blank" rel="noopener" class="fi-footer-social-link">WhatsApp</a>
      </div>
      <div class="fi-footer-info-item">{site.emailContacto}</div>
      <div class="fi-footer-info-item">{site.direccion}</div>
      <div class="fi-footer-info-item">{site.horario}</div>
    </div>
  </div>
  <p class="fi-footer-copyright">
    Copyright © Todos los derechos reservados – Agencia Fi {year}
  </p>
</footer>

<a href={site.whatsapp} target="_blank" rel="noopener" class="fi-whatsapp-float" aria-label="Escríbenos por WhatsApp">
  <svg class="fi-wa-icon-img" viewBox="0 0 32 32" fill="#fff" xmlns="http://www.w3.org/2000/svg">
    <path d="M16.04 3C9.4 3 4 8.4 4 15.04c0 2.13.56 4.2 1.62 6.03L4 29l8.13-1.58a12 12 0 0 0 3.9.66h.01C22.68 28.08 28 22.68 28 16.04 28 9.4 22.68 3 16.04 3zm0 22.06c-1.2 0-2.38-.2-3.5-.6l-.25-.1-4.83.94.97-4.7-.16-.26a9.9 9.9 0 0 1-1.5-5.25c0-5.5 4.48-9.97 10-9.97 5.5 0 9.96 4.47 9.96 9.97 0 5.51-4.46 9.97-9.96 9.97zm5.46-7.47c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.22 3.08.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35z"/>
  </svg>
</a>
