{
  "name": "agenciafi-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Sitio de Agencia Fi (agencia de comunicaciones, Santiago) — OneClickLanding / Pandora Studio. Astro estático + blog Mirada Fi autogestionado con TinaCMS.",
