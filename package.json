    "@fontsource/space-mono": "^5.2.9",
    "@tinacms/cli": "^2.5.2",
    "astro": "^5.0.0",
    "basic-ftp": "^6.0.1",
    "tinacms": "^3.9.4",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0"
  }
